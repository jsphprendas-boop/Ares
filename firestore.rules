rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'userId', 'displayName', 'preferredCurrency', 'language', 'createdAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.preferredCurrency is string && data.preferredCurrency.size() <= 5 &&
             data.language is string && data.language.size() <= 5 &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'category', 'type', 'date', 'currency']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.amount is number && data.amount >= 0 &&
             data.category is string && data.category.size() <= 50 &&
             data.type in ['income', 'expense'] &&
             data.date is string && data.date.size() <= 50 &&
             data.currency is string && data.currency.size() <= 5 &&
             (data.keys().hasAll(['note']) ? (data.note is string && data.note.size() <= 500) : true);
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['userId', 'category', 'amount', 'period', 'currency']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.category is string && data.category.size() <= 50 &&
             data.amount is number && data.amount >= 0 &&
             data.period is string && data.period.size() <= 20 &&
             data.currency is string && data.currency.size() <= 5;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['userId', 'name', 'targetAmount', 'currentAmount', 'currency']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.targetAmount is number && data.targetAmount >= 0 &&
             data.currentAmount is number && data.currentAmount >= 0 &&
             data.currency is string && data.currency.size() <= 5 &&
             (data.keys().hasAll(['deadline']) ? (data.deadline is string && data.deadline.size() <= 50) : true);
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'preferredCurrency', 'language']) ||
        incoming().diff(existing()).affectedKeys().size() == 0
      );
    }

    match /transactions/{transactionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidTransaction(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Transactions are usually immutable in this app's UI, only deleted.
    }

    match /budgets/{budgetId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidBudget(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidBudget(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'category', 'currency'])
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /goals/{goalId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidGoal(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidGoal(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['currentAmount', 'name', 'targetAmount', 'deadline', 'currency'])
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
